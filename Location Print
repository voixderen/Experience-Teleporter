-- Teleporter Tools Ultimate (Generated)
-- Features:
-- Save/Load permanent JSON
-- Drag UI
-- Minimize / Close
-- Dynamic slots (1-100)
-- Auto Route Teleport
-- Delay saved
-- Loop Counter
-- Auto TP always OFF on inject

local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local UIS = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local Player = Players.LocalPlayer

local SAVE_FILE = "LocationSaver_"..game.PlaceId..".json"
local MAX_LIMIT = 100

local Data = {
    SlotCount = 21,
    Delay = 5,
    Locations = {}
}

local AutoRunning = false
local LoopCount = 0
local CurrentSlot = "-"

local function SaveData()
    writefile(SAVE_FILE, HttpService:JSONEncode(Data))
end

local function LoadData()
    if isfile and isfile(SAVE_FILE) then
        local ok,res = pcall(function()
            return HttpService:JSONDecode(readfile(SAVE_FILE))
        end)
        if ok and type(res)=="table" then
            Data = res
            Data.Locations = Data.Locations or {}
            Data.Delay = tonumber(Data.Delay) or 5
            Data.SlotCount = math.clamp(tonumber(Data.SlotCount) or 21,1,MAX_LIMIT)
        end
    end
end

LoadData()

pcall(function()
    local old = CoreGui:FindFirstChild("LocationSaverUltimate")
    if old then old:Destroy() end
end)

local gui = Instance.new("ScreenGui")
gui.Name = "LocationSaverUltimate"
gui.ResetOnSpawn = false
gui.Parent = CoreGui

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0,700,0,500)
frame.Position = UDim2.new(.5,-350,.5,-250)
frame.Parent = gui

local top = Instance.new("Frame")
top.Size = UDim2.new(1,0,0,35)
top.Parent = frame

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1,-80,1,0)
title.BackgroundTransparency = 1
title.Text = "Teleporter Tools Ultimate"
title.Parent = top

local minBtn = Instance.new("TextButton")
minBtn.Size = UDim2.new(0,35,0,30)
minBtn.Position = UDim2.new(1,-75,0,2)
minBtn.Text = "-"
minBtn.Parent = top

local closeBtn = Instance.new("TextButton")
closeBtn.Size = UDim2.new(0,35,0,30)
closeBtn.Position = UDim2.new(1,-38,0,2)
closeBtn.Text = "X"
closeBtn.Parent = top

local content = Instance.new("Frame")
content.Size = UDim2.new(1,0,1,-35)
content.Position = UDim2.new(0,0,0,35)
content.Parent = frame

local info = Instance.new("TextLabel")
info.Size = UDim2.new(1,0,0,25)
info.BackgroundTransparency = 1
info.Parent = content

local delayBox = Instance.new("TextBox")
delayBox.Size = UDim2.new(0,80,0,25)
delayBox.Position = UDim2.new(0,5,0,25)
delayBox.Text = tostring(Data.Delay)
delayBox.Parent = content

local startBtn = Instance.new("TextButton")
startBtn.Size = UDim2.new(0,80,0,25)
startBtn.Position = UDim2.new(0,90,0,25)
startBtn.Text = "START"
startBtn.Parent = content

local stopBtn = Instance.new("TextButton")
stopBtn.Size = UDim2.new(0,80,0,25)
stopBtn.Position = UDim2.new(0,175,0,25)
stopBtn.Text = "STOP"
stopBtn.Parent = content

local minusBtn = Instance.new("TextButton")
minusBtn.Size = UDim2.new(0,30,0,25)
minusBtn.Position = UDim2.new(0,270,0,25)
minusBtn.Text = "-"
minusBtn.Parent = content

local plusBtn = Instance.new("TextButton")
plusBtn.Size = UDim2.new(0,30,0,25)
plusBtn.Position = UDim2.new(0,335,0,25)
plusBtn.Text = "+"
plusBtn.Parent = content

local slotLabel = Instance.new("TextLabel")
slotLabel.Size = UDim2.new(0,120,0,25)
slotLabel.Position = UDim2.new(0,305,0,25)
slotLabel.BackgroundTransparency = 1
slotLabel.Parent = content

local scroll = Instance.new("ScrollingFrame")
scroll.Size = UDim2.new(1,-10,1,-60)
scroll.Position = UDim2.new(0,5,0,55)
scroll.Parent = content

local grid = Instance.new("UIGridLayout")
grid.CellSize = UDim2.new(0,180,0,80)
grid.Parent = scroll

local Slots = {}

local function GetRoot()
    local c = Player.Character or Player.CharacterAdded:Wait()
    return c:WaitForChild("HumanoidRootPart")
end

local function Teleport(slot)
    local d = Data.Locations[tostring(slot)]
    if not d then return end
    local c = Player.Character
    if c then
        c:PivotTo(CFrame.new(d.Position[1],d.Position[2],d.Position[3]))
    end
end

local function RefreshInfo()
    local filled = 0
    for _ in pairs(Data.Locations) do filled += 1 end
    local loopTime = filled * (tonumber(Data.Delay) or 5)
    info.Text = string.format(
        "AutoTP:%s | Loop:%d | Current:%s | Filled:%d | Loop≈%ds",
        AutoRunning and "ON" or "OFF",
        LoopCount,
        tostring(CurrentSlot),
        filled,
        loopTime
    )
    slotLabel.Text = "Slots: "..Data.SlotCount
end

local function BuildSlots()
    for _,v in ipairs(scroll:GetChildren()) do
        if v:IsA("Frame") then v:Destroy() end
    end
    Slots={}

    for i=1,Data.SlotCount do
        local sf=Instance.new("Frame")
        sf.Parent=scroll

        local lbl=Instance.new("TextLabel")
        lbl.Size=UDim2.new(1,0,0,20)
        lbl.Text="Slot "..i
        lbl.Parent=sf

        local coord=Instance.new("TextLabel")
        coord.Size=UDim2.new(1,0,0,20)
        coord.Position=UDim2.new(0,0,0,20)
        coord.Parent=sf

        local save=Instance.new("TextButton")
        save.Size=UDim2.new(.48,0,0,25)
        save.Position=UDim2.new(0,0,1,-25)
        save.Text="SAVE"
        save.Parent=sf

        local tp=Instance.new("TextButton")
        tp.Size=UDim2.new(.48,0,0,25)
        tp.Position=UDim2.new(.52,0,1,-25)
        tp.Text="TP"
        tp.Parent=sf

        local data=Data.Locations[tostring(i)]
        coord.Text=data and string.format("%.0f %.0f %.0f",data.Position[1],data.Position[2],data.Position[3]) or "-"

        save.MouseButton1Click:Connect(function()
            local r=GetRoot()
            Data.Locations[tostring(i)]={Position={r.Position.X,r.Position.Y,r.Position.Z}}
            SaveData()
            BuildSlots()
            RefreshInfo()
        end)

        tp.MouseButton1Click:Connect(function()
            Teleport(i)
        end)
    end

    task.wait()
    scroll.CanvasSize=UDim2.new(0,0,0,grid.AbsoluteContentSize.Y+10)
end

BuildSlots()
RefreshInfo()

delayBox.FocusLost:Connect(function()
    Data.Delay=math.max(1,tonumber(delayBox.Text) or 5)
    delayBox.Text=tostring(Data.Delay)
    SaveData()
    RefreshInfo()
end)

plusBtn.MouseButton1Click:Connect(function()
    if Data.SlotCount < MAX_LIMIT then
        Data.SlotCount += 1
        SaveData()
        BuildSlots()
        RefreshInfo()
    end
end)

minusBtn.MouseButton1Click:Connect(function()
    if Data.SlotCount > 1 then
        Data.SlotCount -= 1
        SaveData()
        BuildSlots()
        RefreshInfo()
    end
end)

task.spawn(function()
    while gui.Parent do
        task.wait(.5)
        RefreshInfo()
    end
end)

startBtn.MouseButton1Click:Connect(function()
    if AutoRunning then return end
    AutoRunning = true

    task.spawn(function()
        while AutoRunning do
            local filled = {}

            for i=1,Data.SlotCount do
                if Data.Locations[tostring(i)] then
                    table.insert(filled,i)
                end
            end

            if #filled == 0 then
                task.wait(1)
            else
                for _,slot in ipairs(filled) do
                    if not AutoRunning then break end
                    CurrentSlot = slot
                    Teleport(slot)
                    RefreshInfo()
                    task.wait(Data.Delay)
                end
                LoopCount += 1
            end
        end
    end)
end)

stopBtn.MouseButton1Click:Connect(function()
    AutoRunning=false
    CurrentSlot="-"
end)

closeBtn.MouseButton1Click:Connect(function()
    AutoRunning=false
    gui:Destroy()
end)

local minimized=false
minBtn.MouseButton1Click:Connect(function()
    minimized=not minimized
    content.Visible=not minimized
    frame.Size=minimized and UDim2.new(0,700,0,35) or UDim2.new(0,700,0,500)
end)

local dragging=false
local dragStart,startPos

top.InputBegan:Connect(function(input)
    if input.UserInputType==Enum.UserInputType.MouseButton1 then
        dragging=true
        dragStart=input.Position
        startPos=frame.Position
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType==Enum.UserInputType.MouseMovement then
        local delta=input.Position-dragStart
        frame.Position=UDim2.new(
            startPos.X.Scale,startPos.X.Offset+delta.X,
            startPos.Y.Scale,startPos.Y.Offset+delta.Y
        )
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.UserInputType==Enum.UserInputType.MouseButton1 then
        dragging=false
    end
end)

print("Teleporter Tools Ultimate Loaded")
