-- Dragging (Menyeret)
local dragging = false
local dragStart
local startPos

MainFrame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = MainFrame.Position

		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

UIS.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - dragStart

		MainFrame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

-- Functions (Fungsi)
local SlotUIs = {}

local function GetRoot()
	local Character = Player.Character or Player.CharacterAdded:Wait()
	return Character:WaitForChild("HumanoidRootPart")
end

local function SaveLocation(slot)
	local Root = GetRoot()

	SavedLocations[slot] = {
		CFrame = {Root.CFrame:components()},
		Position = {Root.Position.X, Root.Position.Y, Root.Position.Z}
	}

	Status.Text = ("Saved Slot %d"):format(slot)
end

local function TeleportLocation(slot)
	local Data = SavedLocations[slot]

	if not Data then
		Status.Text = ("Slot %d Empty"):format(slot)
		return
	end

	local Character = Player.Character
	if Character then
		Character:PivotTo(CFrame.new(unpack(Data.CFrame)))
	end

	Status.Text = ("Teleported To Slot %d"):format(slot)
end

local function RefreshUI()
	for i = 1, MAX_SLOTS do
		local data = SavedLocations[i]
		if data then
			local Pos = data.Position
			SlotUIs[i].Coord.Text = string.format("%.0f %.0f %.0f", Pos[1], Pos[2], Pos[3])
			SlotUIs[i].SlotFrame.BackgroundColor3 = Color3.fromRGB(65,100,65)
		else
			SlotUIs[i].Coord.Text = "-"
			SlotUIs[i].SlotFrame.BackgroundColor3 = Color3.fromRGB(55,55,55)
		end
	end
end

local function FetchGitHubData()
	if not req then Status.Text = "Executor (eksekutor) tidak mendukung HTTP Request" return nil end
	local response = req({
		Url = "https://api.github.com/gists/" .. GIST_ID,
		Method = "GET",
		Headers = {
			["Authorization"] = "token " .. GITHUB_TOKEN,
			["Accept"] = "application/vnd.github.v3+json"
		}
	})
	
	if response.Success then
		local decoded = HttpService:JSONDecode(response.Body)
		if decoded.files and decoded.files["locations.json"] then
			return HttpService:JSONDecode(decoded.files["locations.json"].content)
		end
	end
	return {}
end

local function LoadFromGitHub()
	Status.Text = "Loading from GitHub..."
	local allData = FetchGitHubData()
	if allData then
		local placeData = allData[ExperienceID] or {}
		SavedLocations = {}
		for k, v in pairs(placeData) do
			SavedLocations[tonumber(k)] = v
		end
		RefreshUI()
		Status.Text = "Loaded data for Experience ID (ID Pengalaman): " .. ExperienceID
	else
		Status.Text = "Gagal memuat data dari GitHub"
	end
end

local function SaveToGitHub()
	if not req then Status.Text = "Executor (eksekutor) tidak mendukung HTTP Request" return end
	Status.Text = "Saving to GitHub..."
	
	local allData = FetchGitHubData() or {}
	allData[ExperienceID] = SavedLocations
	
	local newContent = HttpService:JSONEncode(allData)
	
	local response = req({
		Url = "https://api.github.com/gists/" .. GIST_ID,
		Method = "PATCH",
		Headers = {
			["Authorization"] = "token " .. GITHUB_TOKEN,
			["Accept"] = "application/vnd.github.v3+json"
		},
		Body = HttpService:JSONEncode({
			files = {
				["locations.json"] = {
					content = newContent
				}
			}
		})
	})
	
	if response.Success then
		Status.Text = "Saved data to GitHub for Experience ID (ID Pengalaman): " .. ExperienceID
	else
		Status.Text = "Gagal menyimpan data ke GitHub"
	end
end

